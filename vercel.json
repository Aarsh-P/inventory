{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/src/server.ts"
    },
    {
      "source": "/assets/:path*",
      "destination": "frontend/assets/:path*"
    },
    {
      "source": "/favicon.svg",
      "destination": "frontend/favicon.svg"
    },
    {
      "source": "/icons.svg",
      "destination": "frontend/icons.svg"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/index.html"
    }
  ],
  "cleanUrls": true
}
